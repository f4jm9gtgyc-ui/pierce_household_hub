<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Solar Hub</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    :root {
      --bg: #f7f1e8;
      --card: #fffaf2;
      --card-2: #fbf5ec;
      --ink: #241815;
      --muted: #7e7168;
      --line: rgba(90, 62, 39, .16);
      --brown: #5a361f;
      --brown-dark: #2a1710;
      --amber: #f2a000;
      --green: #42680f;
      --red: #9b241d;
      --shadow: 0 14px 35px rgba(50, 32, 18, .07);
      --radius: 18px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(255,255,255,.75), transparent 38%),
        linear-gradient(135deg, #f8f2e8 0%, #f5eee3 100%);
      color: var(--ink);
      padding-bottom: 88px;
    }

    .app {
      width: 100%;
      max-width: 1640px;
      margin: 0 auto;
      padding: 24px;
    }

    header {
      display: grid;
      grid-template-columns: 240px 1fr auto;
      gap: 24px;
      align-items: start;
      margin-bottom: 24px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .sun {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--amber);
      box-shadow: 0 0 0 9px rgba(242,160,0,.13);
      position: relative;
      flex: 0 0 auto;
    }

    .sun::before {
      content: "☀";
      position: absolute;
      inset: -14px;
      display: grid;
      place-items: center;
      color: var(--amber);
      font-size: 70px;
      line-height: 1;
    }

    .brand h1 {
      font-size: 25px;
      margin: 0;
      letter-spacing: -.04em;
    }

    .brand p {
      margin: 2px 0 0;
      font-size: 14px;
      color: var(--ink);
    }

    .page-title h2 {
      margin: 0;
      font-size: 28px;
      letter-spacing: -.04em;
    }

    .page-title p {
      margin: 5px 0 0;
      color: var(--ink);
      font-size: 15px;
    }

    .actions {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .pill-btn {
      border: 1px solid var(--line);
      background: rgba(255,255,255,.55);
      border-radius: 12px;
      padding: 13px 18px;
      font-weight: 700;
      color: var(--brown-dark);
      display: flex;
      gap: 10px;
      align-items: center;
      min-height: 48px;
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 18px;
    }

    .card {
      background: rgba(255,250,242,.78);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .kpi {
      min-height: 176px;
      padding: 22px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .kpi-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start;
    }

    .label {
      font-size: 13px;
      font-weight: 900;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .icon {
      color: var(--brown);
      opacity: .9;
      font-size: 30px;
      line-height: 1;
    }

    .value {
      font-size: 30px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: -.05em;
      margin-top: 14px;
    }

    .value small {
      font-size: 16px;
      letter-spacing: -.02em;
      font-weight: 850;
    }

    .sub {
      color: var(--ink);
      font-size: 14px;
      margin-top: 14px;
    }

    .green { color: var(--green); }
    .red { color: var(--red); }
    .brown { color: var(--brown); }

    .main-grid {
      display: grid;
      grid-template-columns: 1.65fr .9fr .9fr;
      gap: 14px;
    }

    .panel {
      padding: 22px;
      min-height: 330px;
    }

    .panel h3 {
      margin: 0 0 18px;
      font-size: 19px;
      letter-spacing: -.03em;
    }

    .chart {
      width: 100%;
      height: 245px;
    }

    .legend {
      display: flex;
      gap: 30px;
      align-items: center;
      font-size: 13px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }

    .dot {
      display: inline-block;
      width: 16px;
      height: 9px;
      border-radius: 3px;
      margin-right: 8px;
      background: var(--brown);
    }

    .dot.light { background: #e4bd8d; }
    .dot.line {
      width: 22px;
      height: 0;
      border-top: 2px dashed var(--brown-dark);
      background: transparent;
      transform: translateY(-3px);
    }

    .flow {
      display: grid;
      grid-template-columns: 1fr 68px 1fr;
      align-items: center;
      gap: 10px;
      height: 258px;
    }

    .flow-left {
      display: grid;
      gap: 18px;
    }

    .mini-card {
      border: 1px solid var(--line);
      background: rgba(255,250,242,.7);
      border-radius: 12px;
      padding: 18px;
      text-align: center;
      min-height: 116px;
    }

    .mini-card .emoji {
      font-size: 34px;
      color: var(--amber);
      margin-bottom: 8px;
    }

    .mini-card strong {
      font-size: 20px;
      display: block;
    }

    .mini-card span {
      font-size: 12px;
    }

    .flow-line {
      height: 132px;
      border-left: 3px solid #b98a55;
      border-top: 3px solid var(--brown);
      border-bottom: 3px solid #d7b58c;
      border-radius: 0 16px 16px 0;
    }

    .bill-row, .life-row, .perf-row {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      padding: 9px 0;
      font-size: 15px;
      border-bottom: 1px solid rgba(90,62,39,.08);
    }

    .bill-row.total {
      margin-top: 12px;
      padding-top: 20px;
      border-top: 1px solid var(--line);
      font-weight: 900;
      border-bottom: 0;
    }

    .wide-table {
      grid-column: span 1;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    th {
      text-align: left;
      padding: 9px 10px;
      background: rgba(226, 205, 178, .25);
      font-size: 12px;
      white-space: nowrap;
    }

    td {
      padding: 11px 10px;
      border-bottom: 1px solid rgba(90,62,39,.1);
      white-space: nowrap;
    }

    .center { text-align: center; }
    .right { text-align: right; }

    .gauge-wrap {
      display: grid;
      place-items: center;
      margin: 12px 0 18px;
    }

    .gauge {
      width: 210px;
      height: 112px;
    }

    .bottom-link {
      text-align: center;
      color: var(--brown);
      font-weight: 800;
      margin-top: 14px;
      font-size: 14px;
    }

    .bottom-nav {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      height: 76px;
      background: rgba(247, 241, 232, .86);
      backdrop-filter: blur(14px);
      border-top: 1px solid var(--line);
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 16px;
      z-index: 10;
      padding: 10px 20px;
    }

    .nav-btn {
      border: 1px solid var(--line);
      background: rgba(255,250,242,.75);
      color: var(--brown-dark);
      border-radius: 15px;
      padding: 13px 22px;
      font-weight: 850;
      min-width: 130px;
      display: flex;
      justify-content: center;
      gap: 10px;
      text-decoration: none;
      white-space: nowrap;
    }

    .nav-btn.active {
      background: linear-gradient(135deg, #6b4325, #2b170e);
      color: white;
      border-color: transparent;
    }

    .error {
      display: none;
      margin-bottom: 16px;
      padding: 14px 18px;
      border-radius: 14px;
      background: rgba(155,36,29,.08);
      color: var(--red);
      border: 1px solid rgba(155,36,29,.18);
      font-weight: 750;
    }

    @media (max-width: 1180px) {
      header { grid-template-columns: 1fr; }
      .actions { justify-content: flex-start; }
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .main-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 700px) {
      .app { padding: 16px; }
      .kpi-grid { grid-template-columns: 1fr; }
      .bottom-nav {
        overflow-x: auto;
        justify-content: flex-start;
      }
      .nav-btn { min-width: max-content; }
    }
  </style>
</head>

<body>
  <main class="app">
    <header>
      <section class="brand">
        <div class="sun" aria-hidden="true"></div>
        <div>
          <h1>Solar Hub</h1>
          <p>My Energy Dashboard</p>
        </div>
      </section>

      <section class="page-title">
        <h2>Overview</h2>
        <p>Snapshot of your solar energy and electric usage</p>
      </section>

      <section class="actions">
        <button class="pill-btn">📅 <span id="selectedMonth">Loading...</span></button>
        <button class="pill-btn">⇩ Export</button>
      </section>
    </header>

    <div id="errorBox" class="error"></div>

    <section class="kpi-grid">
      <article class="card kpi">
        <div>
          <div class="kpi-top">
            <div class="label">Solar Generated</div>
            <div class="icon">☀</div>
          </div>
          <div class="value brown"><span id="solarGenerated">--</span> <small>kWh</small></div>
        </div>
        <div class="sub green">▲ 18% vs previous month</div>
      </article>

      <article class="card kpi">
        <div>
          <div class="kpi-top">
            <div class="label">Home Usage</div>
            <div class="icon">⌂</div>
          </div>
          <div class="value"><span id="homeUsage">--</span> <small>kWh</small></div>
        </div>
        <div class="sub green">▲ 5% vs previous month</div>
      </article>

      <article class="card kpi">
        <div>
          <div class="kpi-top">
            <div class="label">Net Energy</div>
            <div class="icon">ϟ</div>
          </div>
          <div class="value green"><span id="netEnergy">--</span> <small>kWh</small></div>
        </div>
        <div class="sub" id="netEnergyLabel">Sent to FPL</div>
      </article>

      <article class="card kpi">
        <div>
          <div class="kpi-top">
            <div class="label">Net Meter Bank</div>
            <div class="icon">▣</div>
          </div>
          <div class="value green">+<span id="netMeterBank">--</span> <small>kWh</small></div>
        </div>
        <div>
          <div class="sub">Banked for future use</div>
          <div class="sub">Equivalent Value</div>
          <div class="value green" style="font-size:22px;">$<span id="bankValue">--</span></div>
        </div>
      </article>

      <article class="card kpi">
        <div>
          <div class="kpi-top">
            <div class="label">Current FPL Bill</div>
            <div class="icon">▤</div>
          </div>
          <div class="value red">$<span id="currentBill">--</span></div>
        </div>
        <div class="sub">Due <span id="dueDate">--</span></div>
      </article>

      <article class="card kpi">
        <div>
          <div class="kpi-top">
            <div class="label">Solar Savings (YTD)</div>
            <div class="icon">♧</div>
          </div>
          <div class="value green">$<span id="solarSavings">198.24</span></div>
        </div>
        <div class="sub green">▲ 12% vs previous month</div>
      </article>

      <article class="card kpi">
        <div>
          <div class="kpi-top">
            <div class="label">Lifetime Savings</div>
            <div class="icon">▥</div>
          </div>
          <div class="value green">$<span id="lifetimeSavings">8,421</span></div>
        </div>
        <div class="sub">Since <span id="inServiceTop">Jun 2022</span></div>
      </article>
    </section>

    <section class="main-grid">
      <article class="card panel">
        <h3>Energy Trend (12 Months)</h3>
        <div class="legend">
          <span><i class="dot"></i> Solar Generated (kWh)</span>
          <span><i class="dot light"></i> Home Usage (kWh)</span>
          <span><i class="dot line"></i> Net Energy (kWh)</span>
        </div>
        <svg id="energyChart" class="chart" viewBox="0 0 820 260" preserveAspectRatio="none"></svg>
      </article>

      <article class="card panel">
        <h3>Energy Flow - <span id="flowMonth">--</span></h3>
        <div class="flow">
          <div class="flow-left">
            <div class="mini-card">
              <div class="emoji">☀</div>
              <strong><span id="flowSolar">--</span> kWh</strong>
              <span>Solar Generated</span>
            </div>
            <div class="mini-card">
              <div class="emoji">⌂</div>
              <strong><span id="flowHome">--</span> kWh</strong>
              <span>Home Usage</span>
            </div>
          </div>
          <div class="flow-line"></div>
          <div class="flow-left">
            <div class="mini-card">
              <div class="emoji">♜</div>
              <strong class="green"><span id="flowSent">--</span> kWh</strong>
              <span>Sent to FPL</span>
            </div>
            <div class="mini-card">
              <div class="emoji">⊙</div>
              <strong><span id="flowFrom">--</span> kWh</strong>
              <span>From FPL</span>
            </div>
          </div>
        </div>
      </article>

      <article class="card panel">
        <h3>FPL Bill Breakdown - <span id="billMonth">--</span></h3>
        <div class="bill-row"><span>EV Program (Flat Fee)</span><strong>$<span id="evFee">--</span></strong></div>
        <div class="bill-row"><span>Base FPL Service</span><strong>$<span id="baseFee">--</span></strong></div>
        <div class="bill-row"><span>Energy Charge</span><strong>$<span id="energyCharge">--</span></strong></div>
        <div class="bill-row"><span>Solar Credit</span><strong class="green">$<span id="solarCredit">--</span></strong></div>
        <div class="bill-row"><span>Taxes & Fees</span><strong>$<span id="taxesFees">--</span></strong></div>
        <div class="bill-row total"><span>Total Current Bill</span><strong class="red">$<span id="billTotal">--</span></strong></div>
        <div class="sub">Due Date: <strong id="billDue">--</strong></div>
        <div class="bottom-link">View Full Bill History</div>
      </article>

      <article class="card panel wide-table">
        <h3>Monthly Energy Overview</h3>
        <table>
          <thead>
            <tr>
              <th>Month</th>
              <th class="right">Solar Generated (kWh)</th>
              <th class="right">Home Usage (kWh)</th>
              <th class="right">Net Energy (kWh)</th>
              <th class="right">Sent to FPL (kWh)</th>
              <th class="right">From FPL (kWh)</th>
            </tr>
          </thead>
          <tbody id="monthlyRows"></tbody>
        </table>
        <div class="bottom-link">View All Months</div>
      </article>

      <article class="card panel">
        <h3>Solar Performance (<span id="perfMonth">--</span>)</h3>
        <div class="gauge-wrap">
          <svg class="gauge" viewBox="0 0 220 120">
            <path d="M30 100 A80 80 0 0 1 190 100" fill="none" stroke="#eadfce" stroke-width="20" stroke-linecap="round"/>
            <path d="M30 100 A80 80 0 0 1 185 76" fill="none" stroke="#6b4325" stroke-width="20" stroke-linecap="round"/>
            <text x="110" y="78" text-anchor="middle" font-size="34" font-weight="900">96%</text>
            <text x="110" y="102" text-anchor="middle" font-size="14" font-weight="700">Performance</text>
          </svg>
        </div>
        <div class="perf-row"><span>Actual Generated</span><strong><span id="actualGenerated">--</span> kWh</strong></div>
        <div class="perf-row"><span>Expected Generated ⓘ</span><strong>1,300 kWh</strong></div>
        <div class="perf-row"><span>Performance</span><strong class="green">96%</strong></div>
        <div class="bottom-link">View Performance History</div>
      </article>

      <article class="card panel">
        <h3>System Lifetime</h3>
        <div class="life-row"><span>☀ Total Generated</span><strong><span id="lifeGenerated">--</span> kWh</strong></div>
        <div class="life-row"><span>♜ Total Sent to FPL</span><strong><span id="lifeSent">--</span> kWh</strong></div>
        <div class="life-row"><span>⊙ Total From FPL</span><strong><span id="lifeFrom">--</span> kWh</strong></div>
        <div class="life-row"><span>♧ CO₂ Offset</span><strong>18.7 Tons</strong></div>
        <div class="life-row"><span>♤ Equivalent Trees Planted</span><strong>217 Trees</strong></div>
        <div class="sub" style="margin-top:22px;">Since <span id="inService">--</span></div>
      </article>
    </section>
  </main>

  <nav class="bottom-nav">
    <a class="nav-btn active" href="./index.html">⌂ Overview</a>
    <a class="nav-btn" href="#">▥ Monthly Energy</a>
    <a class="nav-btn" href="#">▤ FPL Billing</a>
    <a class="nav-btn" href="#">▦ Solar Performance</a>
    <a class="nav-btn" href="#">Ⓢ Financial ROI</a>
    <a class="nav-btn" href="#">▧ Reports</a>
    <a class="nav-btn" href="#">⚙ Settings</a>
  </nav>

  <script>
    const SUPABASE_URL = "https://jzijopsswwqnhmrjbwgh.supabase.co";
    const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp6aWpvcHNzd3dxbmhtcmpid2doIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE5MDg4MzMsImV4cCI6MjA5NzQ4NDgzM30.xINNWvchRGPr7hlcrSV98u_gsH2HFiQ_wdlXbGQ6MkM";

    const client = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    const money = value => Number(value || 0).toLocaleString(undefined, {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });

    const number = value => Number(value || 0).toLocaleString();

    function showError(message) {
      const box = document.getElementById("errorBox");
      box.textContent = message;
      box.style.display = "block";
    }

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    async function loadSolarHub() {
      try {
        const [{ data: monthly, error: monthlyError }, { data: bills, error: billsError }, { data: system, error: systemError }] =
          await Promise.all([
            client.from("solar_monthly").select("*").order("created_at", { ascending: false }),
            client.from("fpl_bills").select("*").order("created_at", { ascending: false }).limit(1),
            client.from("solar_system").select("*").order("id", { ascending: false }).limit(1)
          ]);

        if (monthlyError) throw monthlyError;
        if (billsError) throw billsError;
        if (systemError) throw systemError;

        const latest = monthly?.[0];
        const bill = bills?.[0];
        const sys = system?.[0];

        if (!latest) throw new Error("No solar_monthly data found.");
        if (!bill) throw new Error("No fpl_bills data found.");
        if (!sys) throw new Error("No solar_system data found.");

        setText("selectedMonth", latest.month);
        setText("flowMonth", latest.month);
        setText("billMonth", latest.month);
        setText("perfMonth", latest.month);

        setText("solarGenerated", number(latest.solar_generated_kwh));
        setText("homeUsage", number(latest.home_usage_kwh));
        setText("netEnergy", `${latest.net_energy_kwh >= 0 ? "+" : ""}${number(latest.net_energy_kwh)}`);
        setText("netEnergyLabel", latest.net_energy_kwh >= 0 ? "Sent to FPL" : "From FPL");

        setText("netMeterBank", number(latest.net_meter_bank_kwh));
        setText("bankValue", money(Number(latest.net_meter_bank_kwh || 0) * 0.125));

        setText("currentBill", money(bill.total_bill));
        setText("dueDate", bill.due_date);
        setText("billDue", bill.due_date);
        setText("billTotal", money(bill.total_bill));
        setText("evFee", money(bill.ev_program_fee));
        setText("baseFee", money(bill.base_service_fee));
        setText("energyCharge", money(bill.energy_charge));
        setText("solarCredit", money(bill.solar_credit));
        setText("taxesFees", money(bill.taxes_fees));

        setText("flowSolar", number(latest.solar_generated_kwh));
        setText("flowHome", number(latest.home_usage_kwh));
        setText("flowSent", number(latest.sent_to_fpl_kwh));
        setText("flowFrom", number(latest.from_fpl_kwh));
        setText("actualGenerated", number(latest.solar_generated_kwh));

        setText("inService", sys.in_service_since);
        setText("inServiceTop", sys.in_service_since);

        const totalGenerated = monthly.reduce((sum, row) => sum + Number(row.solar_generated_kwh || 0), 0);
        const totalSent = monthly.reduce((sum, row) => sum + Number(row.sent_to_fpl_kwh || 0), 0);
        const totalFrom = monthly.reduce((sum, row) => sum + Number(row.from_fpl_kwh || 0), 0);

        setText("lifeGenerated", number(totalGenerated));
        setText("lifeSent", number(totalSent));
        setText("lifeFrom", number(totalFrom));

        renderMonthlyTable(monthly);
        renderEnergyChart(monthly.slice().reverse());
      } catch (error) {
        console.error(error);
        showError("Solar Hub could not load Supabase data. Check your Supabase URL, anon key, table names, and Row Level Security settings. Because naturally one missing setting can ruin an otherwise peaceful evening.");
      }
    }

    function renderMonthlyTable(rows) {
      const tbody = document.getElementById("monthlyRows");
      tbody.innerHTML = rows.map(row => {
        const net = Number(row.net_energy_kwh || 0);
        return `
          <tr>
            <td><strong>${row.month}</strong></td>
            <td class="right">${number(row.solar_generated_kwh)}</td>
            <td class="right">${number(row.home_usage_kwh)}</td>
            <td class="right ${net >= 0 ? "green" : "red"}"><strong>${net >= 0 ? "+" : ""}${number(net)}</strong></td>
            <td class="right">${number(row.sent_to_fpl_kwh)}</td>
            <td class="right">${number(row.from_fpl_kwh)}</td>
          </tr>
        `;
      }).join("");
    }

    function renderEnergyChart(rows) {
      const svg = document.getElementById("energyChart");
      const width = 820;
      const height = 260;
      const pad = { top: 18, right: 18, bottom: 34, left: 58 };
      const plotW = width - pad.left - pad.right;
      const plotH = height - pad.top - pad.bottom;

      const maxY = 2000;
      const minY = -1000;
      const y = value => pad.top + ((maxY - value) / (maxY - minY)) * plotH;
      const barGroup = plotW / Math.max(rows.length, 1);
      const barW = Math.min(15, barGroup * .2);

      let html = "";

      for (let tick = -1000; tick <= 2000; tick += 500) {
        const yy = y(tick);
        html += `<line x1="${pad.left}" y1="${yy}" x2="${width - pad.right}" y2="${yy}" stroke="rgba(90,62,39,.14)" />`;
        html += `<text x="8" y="${yy + 4}" font-size="12" fill="#241815">${tick.toLocaleString()}</text>`;
      }

      html += `<text x="8" y="16" font-size="12" fill="#241815">kWh</text>`;

      const points = rows.map((row, i) => {
        const x = pad.left + i * barGroup + barGroup / 2;
        return `${x},${y(Number(row.net_energy_kwh || 0))}`;
      }).join(" ");

      rows.forEach((row, i) => {
        const center = pad.left + i * barGroup + barGroup / 2;
        const solar = Number(row.solar_generated_kwh || 0);
        const usage = Number(row.home_usage_kwh || 0);

        html += `<rect x="${center - barW - 2}" y="${y(solar)}" width="${barW}" height="${y(0) - y(solar)}" rx="3" fill="#6b4325" />`;
        html += `<rect x="${center + 2}" y="${y(usage)}" width="${barW}" height="${y(0) - y(usage)}" rx="3" fill="#e4bd8d" />`;

        const label = row.month.replace(" 20", " '");
        html += `<text x="${center}" y="${height - 8}" font-size="11" text-anchor="middle" fill="#241815">${label}</text>`;
      });

      html += `<polyline points="${points}" fill="none" stroke="#2a1710" stroke-width="2" stroke-dasharray="7 7" />`;
      html += `<line x1="${pad.left}" y1="${y(0)}" x2="${width - pad.right}" y2="${y(0)}" stroke="rgba(90,62,39,.22)" />`;

      svg.innerHTML = html;
    }

    loadSolarHub();
  </script>
</body>
</html>
